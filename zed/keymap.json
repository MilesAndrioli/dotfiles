[
    {
        "bindings": {
            // dock toggling
            "ctrl-shift-g": "workspace::ToggleLeftDock",
            "ctrl-shift-e": "workspace::ToggleRightDock",
            "ctrl-shift-`": "workspace::ToggleBottomDock",

            // tab navigation
            "ctrl-q": "pane::ActivatePreviousItem",
            "ctrl-e": "pane::ActivateNextItem",

            "ctrl-r": "workspace::ToggleZoom",
        },
    },
    // pane creation
    {
        "context": "FileFinder > Picker > Editor",
        "bindings": {
            "ctrl-s": "pane::SplitDown",
            "ctrl-d": "pane::SplitRight",
        },
    },
]
