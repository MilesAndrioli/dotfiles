[
    {
        "unbind": {
            "ctrl-i": "editor::ShowSignatureHelp",
            "ctrl-l": "editor::SelectLine",
        },
    },
    {
        "bindings": {
            "ctrl-f1": "workspace::ToggleLeftDock",
            "ctrl-f2": "workspace::ToggleRightDock",
            "ctrl-f3": "workspace::ToggleBottomDock",

            "ctrl-q": "pane::ActivatePreviousItem",
            "ctrl-e": "pane::ActivateNextItem",

            "ctrl-enter": "workspace::ToggleZoom",
        },
    },
    // tmux creation
    {
        "context": "FileFinder > Picker > Editor",
        "bindings": {
            "ctrl-i": "pane::SplitUp",
            "ctrl-j": "pane::SplitLeft",
            "ctrl-k": "pane::SplitDown",
            "ctrl-l": "pane::SplitRight",
        },
    },
    // tmux movement
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-i": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneDown",
            "ctrl-l": "workspace::ActivatePaneRight",
        },
    },
]
